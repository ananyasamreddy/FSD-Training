---- Create Users Table

SQL> CREATE TABLE Events (
  2      event_id NUMBER(10) PRIMARY KEY,
  3      title VARCHAR2(200) NOT NULL,
  4      description VARCHAR2(500),
  5      city VARCHAR2(100) NOT NULL,
  6      start_date DATE NOT NULL,
  7      end_date DATE NOT NULL,
  8      status VARCHAR2(20)
  9          CHECK (status IN ('upcoming', 'completed', 'cancelled')),
 10      organizer_id NUMBER(10),
 11  constraint fk_organizer foreign key(organizer_id) references Users(user_id));

